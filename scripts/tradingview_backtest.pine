// ═══════════════════════════════════════════════════════════════════════
// Alpha-Flow 4-System Momentum Strategy v2 — TradingView Backtester
// ═══════════════════════════════════════════════════════════════════════
// v2 FIXES vs v1:
//   1. Regime filter: only trade when price > 50 SMA (uptrend)
//   2. Signal confirmation: require 3 consecutive bars above threshold
//   3. Higher entry threshold: 1.0 (was 0.5 — way too noisy)
//   4. Weighted systems: S2 (Elder) + S4 (HA+Hull) get 30% each,
//      S1 (ADX+TRIX) gets 25%, S3 (Renko approx) gets 15%
//   5. Position sizing: 10% risk-per-trade (was 100% equity!)
//   6. Trailing stop: Chandelier exit (3× ATR from recent high)
//   7. Cooldown: 5-bar minimum between trades to avoid whipsaw
//   8. Volume filter: only enter on above-average volume days
//   9. Separate long/short logic with distinct thresholds
//  10. Multi-timeframe: optional weekly trend confirmation
//
// Replicates scoring from momentum_indicators.py + momentum_config.py
// ═══════════════════════════════════════════════════════════════════════

//@version=5
strategy("Alpha-Flow Momentum v2", 
     overlay=true, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=10,
     initial_capital=100000,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=1,
     pyramiding=0,
     calc_on_every_tick=false)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  INPUTS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// System parameters (match momentum_config.py)
adx_period    = input.int(14, "ADX Period", group="Indicators")
trix_period   = input.int(14, "TRIX Period", group="Indicators")
trix_signal   = input.int(9, "TRIX Signal", group="Indicators")
stoch_k_len   = input.int(14, "Stoch %K Length", group="Indicators")
stoch_d_len   = input.int(3, "Stoch %D Smoothing", group="Indicators")
stoch_smooth  = input.int(3, "Stoch Smoothing", group="Indicators")
stoch_ob      = input.float(80, "Stoch Overbought", group="Indicators")
stoch_os      = input.float(20, "Stoch Oversold", group="Indicators")
elder_ema_len = input.int(13, "Elder EMA", group="Indicators")
macd_fast     = input.int(12, "MACD Fast", group="Indicators")
macd_slow     = input.int(26, "MACD Slow", group="Indicators")
macd_sig_len  = input.int(9, "MACD Signal", group="Indicators")
renko_atr_len = input.int(14, "Renko ATR Period", group="Indicators")
hma_period    = input.int(20, "Hull MA Period", group="Indicators")

// System weights (v2: downweight noisy Renko approximation)
w1 = input.float(0.25, "S1 Weight (ADX+TRIX)", minval=0, maxval=1, step=0.05, group="System Weights")
w2 = input.float(0.30, "S2 Weight (Elder)", minval=0, maxval=1, step=0.05, group="System Weights")
w3 = input.float(0.15, "S3 Weight (Renko)", minval=0, maxval=1, step=0.05, group="System Weights")
w4 = input.float(0.30, "S4 Weight (HA+Hull)", minval=0, maxval=1, step=0.05, group="System Weights")

// Strategy parameters (v2: much more conservative)
entry_threshold    = input.float(1.0, "Long Entry Threshold", minval=0.3, maxval=2.0, step=0.1, group="Strategy")
exit_threshold     = input.float(0.0, "Long Exit Threshold", minval=-1.0, maxval=0.5, step=0.1, group="Strategy")
confirm_bars       = input.int(3, "Confirmation Bars", minval=1, maxval=10, group="Strategy", tooltip="Score must stay above threshold for this many bars")
cooldown_bars      = input.int(5, "Cooldown After Exit", minval=0, maxval=20, group="Strategy", tooltip="Minimum bars between trades")

// Risk management
risk_pct           = input.float(10.0, "Position Size %", minval=1, maxval=50, step=1, group="Risk Management")
trail_atr_mult     = input.float(3.0, "Trailing Stop ATR ×", minval=1.0, maxval=6.0, step=0.5, group="Risk Management")
trail_atr_len      = input.int(14, "Trailing Stop ATR Period", group="Risk Management")
use_fixed_tp       = input.bool(false, "Use Fixed Take Profit", group="Risk Management")
tp_atr_mult        = input.float(4.0, "Take Profit ATR ×", minval=1.0, maxval=10.0, step=0.5, group="Risk Management")

// Filters
use_regime_filter  = input.bool(true, "Regime Filter (Price > SMA)", group="Filters")
regime_sma_len     = input.int(50, "Regime SMA Length", minval=20, maxval=200, group="Filters")
use_volume_filter  = input.bool(true, "Volume Filter (> avg)", group="Filters")
vol_avg_len        = input.int(20, "Volume Average Length", group="Filters")
vol_mult           = input.float(1.0, "Volume Multiplier", minval=0.5, maxval=3.0, step=0.1, group="Filters", tooltip="Volume must be > avg × this")
use_rsi_guard      = input.bool(true, "RSI Overbought Guard", group="Filters", tooltip="Don't enter when RSI > 75")
rsi_guard_level    = input.float(75, "RSI Guard Level", minval=60, maxval=90, group="Filters")


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  SYSTEM 1: ADX + TRIX + Full Stochastics
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

up_move   = high - high[1]
down_move = low[1] - low
plus_dm   = (up_move > down_move and up_move > 0) ? up_move : 0.0
minus_dm  = (down_move > up_move and down_move > 0) ? down_move : 0.0

atr_val   = ta.rma(ta.tr(true), adx_period)
plus_di   = 100 * ta.rma(plus_dm, adx_period) / atr_val
minus_di  = 100 * ta.rma(minus_dm, adx_period) / atr_val
dx        = 100 * math.abs(plus_di - minus_di) / (plus_di + minus_di)
adx       = ta.rma(dx, adx_period)

ema1_trix  = ta.ema(close, trix_period)
ema2_trix  = ta.ema(ema1_trix, trix_period)
ema3_trix  = ta.ema(ema2_trix, trix_period)
trix_val   = 10000 * (ema3_trix - ema3_trix[1]) / ema3_trix[1]
trix_sig_v = ta.ema(trix_val, trix_signal)

stoch_raw_k = ta.stoch(close, high, low, stoch_k_len)
stoch_k_v   = ta.sma(stoch_raw_k, stoch_smooth)
stoch_d_v   = ta.sma(stoch_k_v, stoch_d_len)

has_trend    = adx > 20
strong_trend = adx > 25
trix_bullish = trix_val > 0 and trix_val > trix_val[1]
trix_bearish = trix_val < 0 and trix_val < trix_val[1]
trix_cross_up = ta.crossover(trix_val, trix_sig_v)
trix_cross_dn = ta.crossunder(trix_val, trix_sig_v)
di_bullish   = plus_di > minus_di
di_bearish   = minus_di > plus_di
s_oversold   = stoch_k_v < stoch_os
s_overbought = stoch_k_v > stoch_ob

score1 = 0.0
if has_trend and di_bullish and trix_bullish
    score1 := strong_trend ? 1.5 : 1.0
    if s_oversold
        score1 := 2.0
    else if s_overbought
        score1 := score1 * 0.6
else if has_trend and di_bearish and trix_bearish
    score1 := strong_trend ? -1.5 : -1.0
    if s_overbought
        score1 := -2.0
    else if s_oversold
        score1 := score1 * 0.6
else if trix_cross_up
    score1 := 0.8
else if trix_cross_dn
    score1 := -0.8
else if trix_bullish
    score1 := 0.3
else if trix_bearish
    score1 := -0.3

score1 := math.max(-2.0, math.min(2.0, score1))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  SYSTEM 2: Elder Impulse
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

elder_ema     = ta.ema(close, elder_ema_len)
macd_line     = ta.ema(close, macd_fast) - ta.ema(close, macd_slow)
macd_sig_line = ta.ema(macd_line, macd_sig_len)
macd_hist_v   = macd_line - macd_sig_line

ema_rising    = elder_ema > elder_ema[1]
hist_rising   = macd_hist_v > macd_hist_v[1]

is_green = ema_rising and hist_rising
is_red   = (not ema_rising) and (not hist_rising)

consec_green = 0
consec_red   = 0
for i = 0 to 19
    if is_green[i]
        consec_green += 1
    else
        break
for i = 0 to 19
    if is_red[i]
        consec_red += 1
    else
        break

hist_std = ta.stdev(macd_hist_v, 50)
hist_z   = hist_std > 0 ? macd_hist_v / hist_std : 0.0

score2 = 0.0
if is_green
    base2 = consec_green >= 10 ? 2.0 : consec_green >= 5 ? 1.5 : 1.0
    score2 := math.min(base2 + 0.2 * math.min(hist_z, 2.0), 2.0)
else if is_red
    base2 = consec_red >= 10 ? -2.0 : consec_red >= 5 ? -1.5 : -1.0
    score2 := math.max(base2 + 0.2 * math.max(hist_z, -2.0), -2.0)
else
    score2 := 0.1 * hist_z

score2 := math.max(-2.0, math.min(2.0, score2))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  SYSTEM 3: Renko (ATR approximation) + Stochastics
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// v2: Smoothed Renko approximation using multi-bar ATR breakout
//     instead of single-bar price change (much less noisy)

renko_atr = ta.atr(renko_atr_len)

// v2 FIX: Use smoothed momentum instead of raw bar change
// If close breaks above/below a 5-bar range ± ATR, it's a "brick"
renko_upper_band = ta.highest(close, 5) 
renko_lower_band = ta.lowest(close, 5)
renko_mid        = (renko_upper_band + renko_lower_band) / 2

// Direction: is price trending above or below the midline?
var int renko_dir = 0
if close > renko_mid + renko_atr * 0.3
    renko_dir := 1
else if close < renko_mid - renko_atr * 0.3
    renko_dir := -1

// Smooth the direction to reduce noise: require 2 bars confirmation
renko_confirmed = renko_dir == renko_dir[1] and renko_dir == renko_dir[2]

// Count consecutive confirmed direction
var int renko_consec = 0
if renko_dir != renko_dir[1]
    renko_consec := 1
else
    renko_consec := math.min(renko_consec + 1, 20)

score3 = 0.0
if renko_confirmed and renko_dir == 1
    base3 = math.min(0.5 + 0.3 * math.min(renko_consec, 5), 1.5)
    if s_oversold
        base3 := math.min(base3 + 0.5, 2.0)
    else if s_overbought
        base3 := base3 * 0.5
    score3 := base3
else if renko_confirmed and renko_dir == -1
    base3 = math.max(-0.5 - 0.3 * math.min(renko_consec, 5), -1.5)
    if s_overbought
        base3 := math.max(base3 - 0.5, -2.0)
    else if s_oversold
        base3 := base3 * 0.5
    score3 := base3
// else: unconfirmed = 0

score3 := math.max(-2.0, math.min(2.0, score3))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  SYSTEM 4: Heikin-Ashi + Hull Moving Average
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ha_close_v = (open + high + low + close) / 4.0
var float ha_open_v = na
ha_open_v  := na(ha_open_v[1]) ? (open + close) / 2.0 : (nz(ha_open_v[1]) + nz(ha_close_v[1])) / 2.0
ha_high_v  = math.max(high, ha_open_v, ha_close_v)
ha_low_v   = math.min(low, ha_open_v, ha_close_v)
ha_bullish = ha_close_v > ha_open_v

ha_body       = math.abs(ha_close_v - ha_open_v)
ha_upper_wick = ha_high_v - math.max(ha_open_v, ha_close_v)
ha_lower_wick = math.min(ha_open_v, ha_close_v) - ha_low_v

half_len  = math.max(hma_period / 2, 1)
sqrt_len  = math.max(math.round(math.sqrt(hma_period)), 1)
wma_half  = ta.wma(close, int(half_len))
wma_full  = ta.wma(close, hma_period)
hma_diff  = 2 * wma_half - wma_full
hma_val   = ta.wma(hma_diff, int(sqrt_len))
hma_rising_v = hma_val > hma_val[1]

consec_ha_bull = 0
consec_ha_bear = 0
for i = 0 to 19
    if ha_bullish[i]
        consec_ha_bull += 1
    else
        break
for i = 0 to 19
    if not ha_bullish[i]
        consec_ha_bear += 1
    else
        break

wick_quality = 0.3
if ha_bullish
    wick_quality := ha_lower_wick < ha_body * 0.1 ? 1.0 : ha_lower_wick < ha_body * 0.3 ? 0.6 : 0.3
else
    wick_quality := ha_upper_wick < ha_body * 0.1 ? 1.0 : ha_upper_wick < ha_body * 0.3 ? 0.6 : 0.3

score4 = 0.0
if ha_bullish
    base4 = math.min(0.5 + 0.2 * consec_ha_bull, 1.5)
    score4 := base4 * wick_quality
    if hma_rising_v
        score4 := math.min(score4 + 0.5, 2.0)
    else
        score4 := score4 * 0.4
else
    base4 = math.max(-0.5 - 0.2 * consec_ha_bear, -1.5)
    score4 := base4 * wick_quality
    if not hma_rising_v
        score4 := math.max(score4 - 0.5, -2.0)
    else
        score4 := score4 * 0.4

score4 := math.max(-2.0, math.min(2.0, score4))


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  COMPOSITE SCORE  (v2: WEIGHTED average)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

total_weight = w1 + w2 + w3 + w4
composite = (score1 * w1 + score2 * w2 + score3 * w3 + score4 * w4) / total_weight

// Smooth composite to reduce noise (3-bar EMA)
composite_smooth = ta.ema(composite, 3)

// Agreement bonus: if ≥3 systems agree on direction, boost signal
systems_bullish = (score1 > 0.5 ? 1 : 0) + (score2 > 0.5 ? 1 : 0) + (score3 > 0.5 ? 1 : 0) + (score4 > 0.5 ? 1 : 0)
systems_bearish = (score1 < -0.5 ? 1 : 0) + (score2 < -0.5 ? 1 : 0) + (score3 < -0.5 ? 1 : 0) + (score4 < -0.5 ? 1 : 0)
agreement_bull = systems_bullish >= 3
agreement_bear = systems_bearish >= 3

// Sentiment labels
is_strong_bull = composite_smooth >= 1.5
is_bull        = composite_smooth >= 0.5 and composite_smooth < 1.5
is_bear        = composite_smooth <= -0.5 and composite_smooth > -1.5
is_strong_bear = composite_smooth <= -1.5


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  FILTERS  (v2: the key to not blowing up)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// 1. Regime filter: price must be above SMA (uptrend)
regime_sma   = ta.sma(close, regime_sma_len)
regime_ok    = use_regime_filter ? close > regime_sma : true

// 2. Volume filter: today's volume > average
vol_avg      = ta.sma(volume, vol_avg_len)
volume_ok    = use_volume_filter ? volume > vol_avg * vol_mult : true

// 3. RSI guard: don't buy overbought
rsi_14       = ta.rsi(close, 14)
rsi_ok       = use_rsi_guard ? rsi_14 < rsi_guard_level : true

// 4. Confirmation: score must be above threshold for N consecutive bars
bars_above = 0
for i = 0 to confirm_bars - 1
    if composite_smooth[i] > entry_threshold
        bars_above += 1
confirmed = bars_above >= confirm_bars

// 5. Cooldown: minimum bars since last exit
var int bars_since_exit = 999
bars_since_exit := strategy.position_size == 0 ? bars_since_exit + 1 : 0
cooldown_ok = bars_since_exit >= cooldown_bars

// Combined entry filter
all_filters_pass = regime_ok and volume_ok and rsi_ok and cooldown_ok


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  STRATEGY EXECUTION  (v2: conservative, filtered)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Entry: confirmed composite > threshold + all filters pass
// Bonus: if 3+ systems agree, we can enter at slightly lower threshold
effective_threshold = agreement_bull ? entry_threshold * 0.85 : entry_threshold
long_entry = confirmed and composite_smooth > effective_threshold and all_filters_pass

// Exit conditions (any one triggers):
//   1. Composite drops below exit threshold
//   2. Regime turns bearish (price drops below SMA)
//   3. 3+ systems bearish (strong disagreement)
//   4. Trailing stop hit (handled by strategy.exit)
signal_exit  = composite_smooth < exit_threshold
regime_exit  = use_regime_filter and close < regime_sma * 0.98  // 2% buffer
panic_exit   = agreement_bear
long_exit    = signal_exit or regime_exit or panic_exit

// Trailing stop (Chandelier Exit — ATR from highest high)
trail_atr = ta.atr(trail_atr_len)

if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    bars_since_exit := 0

// Set trailing stop and optional TP after entry
if strategy.position_size > 0
    stop_price = ta.highest(high, 10) - trail_atr * trail_atr_mult
    tp_price   = use_fixed_tp ? strategy.position_avg_price + trail_atr * tp_atr_mult : na
    strategy.exit("Trail", "Long", stop=stop_price, limit=tp_price)

if long_exit and strategy.position_size > 0
    exit_reason = signal_exit ? "Signal" : regime_exit ? "Regime" : "Panic"
    strategy.close("Long", comment=exit_reason)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  VISUAL OVERLAYS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Regime SMA
plot(use_regime_filter ? regime_sma : na, "Regime SMA", color=color.new(color.yellow, 40), linewidth=2)

// Hull MA
plot(hma_val, "Hull MA", color=hma_rising_v ? color.new(color.teal, 30) : color.new(color.orange, 30), linewidth=2)

// Background: subtle regime coloring
bg_color = not regime_ok ? color.new(color.red, 95) :
           is_strong_bull ? color.new(color.green, 90) : 
           is_bull ? color.new(color.green, 94) : 
           is_bear ? color.new(color.red, 94) : 
           color.new(color.gray, 97)
bgcolor(bg_color)

// Entry/Exit markers
plotshape(long_entry and strategy.position_size[1] == 0, "Entry", shape.labelup, location.belowbar, color.new(color.green, 0), text="▲", textcolor=color.white, size=size.small)
plotshape(long_exit and strategy.position_size > 0, "Exit", shape.labeldown, location.abovebar, 
     signal_exit ? color.new(color.orange, 0) : regime_exit ? color.new(color.red, 0) : color.new(color.fuchsia, 0), 
     text="▼", textcolor=color.white, size=size.small)

// Filter status markers (small dots below bars when filters block entry)
plotshape(composite_smooth > entry_threshold and not all_filters_pass, "Blocked", shape.circle, location.belowbar, color.new(color.gray, 60), size=size.tiny)


// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//  DASHBOARD TABLE
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var table dash = table.new(position.bottom_right, 3, 10, 
     bgcolor=color.new(#1a1a2e, 10), border_width=1, border_color=color.new(color.gray, 60))

score_color(float s) =>
    s >= 1.0 ? color.lime : s > 0.3 ? color.green : s > -0.3 ? color.gray : s > -1.0 ? color.orange : color.red

if barstate.islast
    sentiment_str = is_strong_bull ? "🟢 Strong Bull" : is_bull ? "🟢 Bullish" : 
                    is_strong_bear ? "🔴 Strong Bear" : is_bear ? "🔴 Bearish" : "⚪ Neutral"
    
    table.cell(dash, 0, 0, "System", bgcolor=color.new(#16213e, 0), text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, "Score", bgcolor=color.new(#16213e, 0), text_color=color.white, text_size=size.small)
    table.cell(dash, 2, 0, "Wt", bgcolor=color.new(#16213e, 0), text_color=color.white, text_size=size.small)
    
    table.cell(dash, 0, 1, "ADX+TRIX+Stoch", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(score1, "#.##"), text_color=score_color(score1), text_size=size.tiny)
    table.cell(dash, 2, 1, str.tostring(w1 * 100, "#") + "%", text_color=color.gray, text_size=size.tiny)
    
    table.cell(dash, 0, 2, "Elder Impulse", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(score2, "#.##"), text_color=score_color(score2), text_size=size.tiny)
    table.cell(dash, 2, 2, str.tostring(w2 * 100, "#") + "%", text_color=color.gray, text_size=size.tiny)
    
    table.cell(dash, 0, 3, "Renko+Stoch", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(score3, "#.##"), text_color=score_color(score3), text_size=size.tiny)
    table.cell(dash, 2, 3, str.tostring(w3 * 100, "#") + "%", text_color=color.gray, text_size=size.tiny)
    
    table.cell(dash, 0, 4, "HA+Hull MA", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(score4, "#.##"), text_color=score_color(score4), text_size=size.tiny)
    table.cell(dash, 2, 4, str.tostring(w4 * 100, "#") + "%", text_color=color.gray, text_size=size.tiny)
    
    table.cell(dash, 0, 5, "─── COMPOSITE ───", bgcolor=color.new(#0f3460, 0), text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, str.tostring(composite_smooth, "#.##"), bgcolor=color.new(#0f3460, 0), text_color=score_color(composite_smooth), text_size=size.small)
    table.cell(dash, 2, 5, sentiment_str, bgcolor=color.new(#0f3460, 0), text_color=color.white, text_size=size.tiny)
    
    // Filter status
    table.cell(dash, 0, 6, "─── FILTERS ───", bgcolor=color.new(#1a1a2e, 0), text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, "", bgcolor=color.new(#1a1a2e, 0))
    table.cell(dash, 2, 6, "", bgcolor=color.new(#1a1a2e, 0))
    
    table.cell(dash, 0, 7, "Regime", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 7, regime_ok ? "✓ PASS" : "✗ FAIL", text_color=regime_ok ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 2, 7, "Price " + (regime_ok ? ">" : "<") + " SMA" + str.tostring(regime_sma_len), text_color=color.gray, text_size=size.tiny)
    
    table.cell(dash, 0, 8, "Volume", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 8, volume_ok ? "✓ PASS" : "✗ FAIL", text_color=volume_ok ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 2, 8, "RSI: " + str.tostring(rsi_14, "#.#"), text_color=rsi_ok ? color.gray : color.red, text_size=size.tiny)
    
    table.cell(dash, 0, 9, "Agree", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 9, str.tostring(systems_bullish) + "/4 bull", text_color=agreement_bull ? color.lime : color.gray, text_size=size.tiny)
    table.cell(dash, 2, 9, "Cooldown: " + str.tostring(bars_since_exit) + "b", text_color=cooldown_ok ? color.gray : color.orange, text_size=size.tiny)
